# Required for real LLM-powered agentic workflow.
# Without this key the system falls back to simulated agent responses.
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI-compatible base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: enable Replicate for advanced AI image editing
# Without this key only Sharp (local) image processing is used.
# REPLICATE_API_TOKEN=r8_...

# Server
PORT=3000
