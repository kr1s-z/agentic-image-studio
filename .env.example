# Copy to .env in this directory (gitignored).
# Backend local dev reads this file.

# -----------------------------------------------------------------------------
# Replicate — single token used for all models (Flux + Nano Banana)
# Format: r8_... (Dashboard -> Account -> API tokens)
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=r8_ReplaceWithYourReplicateToken0123456789abcdef

# Server (local backend dev; in-cluster PORT comes from Helm)
PORT=3000

# Optional workflow tuning
# MAX_ITERATIONS=5
