# Copy to values-secrets.local.yaml (gitignored) and fill in key.
# Deploy with Tilt (`tilt up`) or helm manually with -f values-secrets.local.yaml.

backend:
  env:
    createSecret: true
    replicateApiToken: "r8_..."
    langfusePublicKey: "pk-lf-..."
    langfuseSecretKey: "sk-lf-..."
    extra:
      LANGFUSE_BASE_URL: "https://cloud.langfuse.com"
      LLM_MODEL: "openai/gpt-4o"
      LLM_MIN_REQUEST_GAP_MS: "2000"
      MAX_ITERATIONS: "5"
